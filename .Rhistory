TestData <- readRDS(file = "./Development/Data/TestData/CCPTestData.rds")
TestData.n <- readRDS(file = "./Development/Data/TestData/CCPTestData_new.rds")
TestData.Root <- TestData$patient %>%
left_join(diagnosis, by = join_by("_id" == "patient-id"))
library(dplyr)
TestData.Root <- TestData$patient %>%
left_join(diagnosis, by = join_by("_id" == "patient-id"))
TestData.Root <- TestData$patient %>%
left_join(TestData$diagnosis, by = join_by("_id" == "patient-id"))
View(TestData.Root)
TestData.Root <- TestData$patient %>%
left_join(TestData$diagnosis, by = join_by("_id" == "patient-id")) %>%
filter(!is.na("_id.y"))
TestData.Root <- TestData$patient %>%
left_join(TestData$diagnosis, by = join_by("_id" == "patient-id")) %>%
filter(!is.na(.data[["_id.y"]]))
View(TestData.Root)
TestData.Root <- TestData$patient %>%
left_join(TestData$diagnosis, by = join_by("_id" == "patient-id")) %>%
filter(!is.na(.data[["_id.y"]])) %>%
pull("_id")
EligiblePatients <- TestData$patient %>%
left_join(TestData$diagnosis, by = join_by("_id" == "patient-id")) %>%
filter(!is.na(.data[["_id.y"]])) %>%
pull("_id")
TestData$patient <- TestData$patient %>%
filter(.data[["_id.y"]] %in% EligiblePatients)
TestData$patient <- TestData$patient %>%
filter(.data[["_id"]] %in% EligiblePatients)
saveRDS(TestData, "./Development/Data/TestData/CCPTestData_new.rds")
